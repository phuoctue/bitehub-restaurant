# Backend Environment Variables Example for Render Deployment
# Copy these to Render dashboard and fill in production values

PORT=4000
DOMAIN=your-render-app.onrender.com
PROTOCOL=https
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"
DIRECT_URL="postgresql://user:password@host:port/database?sslmode=require"

# Token Secrets (keep same as development or generate new)
ACCESS_TOKEN_SECRET=du_an_BiteHub_restaurant_access
REFRESH_TOKEN_SECRET=du_an_BiteHub_restaurant_refresh

# Token Expiration
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=100d
GUEST_ACCESS_TOKEN_EXPIRES_IN=15m
GUEST_REFRESH_TOKEN_EXPIRES_IN=12h

# Upload & Owner
UPLOAD_FOLDER=uploads
INITIAL_NAME_OWNER=Owner
INITIAL_EMAIL_OWNER=admin@order.com
INITIAL_PASSWORD_OWNER=123456

# Client URLs (update to production Vercel URL)
CLIENT_URL=https://your-vercel-app.vercel.app
GOOGLE_REDIRECT_CLIENT_URL=https://your-vercel-app.vercel.app/oauth

# Google OAuth (same as development)
GOOGLE_CLIENT_ID=809302233885-tfjm9rmc432kqdio5rcvcbccscc9pko7.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_AUTHORIZED_REDIRECT_URI=https://your-render-app.onrender.com/auth/login/google
